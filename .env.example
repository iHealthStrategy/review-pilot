# ===== ReviewPilot configuration (copy to .env) =====

# --- Server ---
PORT=3000
LOG_LEVEL=info
# mock | sqlite | postgres | mongo
DB_DRIVER=mock

# --- MongoDB (when DB_DRIVER=mongo; recommended for stateless cloud deploy) ---
# The URI carries auth/credentials (set it as a secret env var in your platform).
# e.g. mongodb+srv://user:pass@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=reviewpilot

# --- Postgres (when DB_DRIVER=postgres) ---
DATABASE_URL=postgres://user:pass@localhost:5432/reviewpilot
# --- SQLite (when DB_DRIVER=sqlite) ---
DB_SQLITE_PATH=./data/reviewpilot.db

# --- Review engine (default; per-project config can override) ---
# mock | cursor | claude-code | claude-agent | codex
#   claude-code  = Claude Code CLI (headless `claude -p`)
#   claude-agent = Claude Agent SDK (programmatic, agentic, structured output) — recommended
REVIEW_ENGINE=mock
# Agent SDK tuning (used when REVIEW_ENGINE=claude-agent)
REVIEW_AGENT_MODEL=
REVIEW_AGENT_MAX_TURNS=30
# Comma-separated list of engines allowed to be enabled per project
REVIEW_ENGINES_ENABLED=mock,claude-code
# Claude Code CLI auth (required when using the claude-code engine).
# The CLI is installed in the Docker image; it runs as `claude -p` non-interactively.
ANTHROPIC_API_KEY=
# Optional: route Claude through a relay/gateway (must be Anthropic-API-compatible).
# Set the base URL; use ANTHROPIC_AUTH_TOKEN instead of the key if the relay
# expects "Authorization: Bearer".
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
# Optional: override the external engine executable / args (else per-engine defaults).
REVIEW_ENGINE_COMMAND=
REVIEW_ENGINE_ARGS=
# Hard timeout for one external review CLI invocation (ms)
ENGINE_TIMEOUT_MS=600000
# Language for the human-readable finding text (title/detail/suggestion), e.g.
# "Chinese". Empty = English. Applies to all engine reviews (PR / branch /
# scheduled scan). JSON keys, severities, file paths and code identifiers stay
# untranslated.
REVIEW_LANGUAGE=
# Per-repo project-understanding cache: the agent explores the repo once and the
# summary grounds future PR reviews (refreshed after the TTL). Default 7 days.
PROJECT_INSIGHT_CACHE=true
PROJECT_INSIGHT_TTL_MS=604800000
# Also post line-level PR comments for findings that carry a line
INLINE_COMMENTS=false
# Publish a Check Run (✅/❌ + inline annotations) on each review
PUBLISH_CHECK_RUN=true
# Gate: Check Run fails (and blocks merge if required) at this severity or worse.
# One of info|minor|major|critical; empty = advisory only.
FAIL_ON_SEVERITY=
# Noise reduction: keep only findings on lines the PR actually changed
ONLY_CHANGED_LINES=false

# --- Structural context (code-review-graph) ---
# Enrich the review prompt with risk-scored hotspots, test gaps and affected
# flows from a code graph. ON by default — the Docker image bakes in
# `code-review-graph` (via uv). Best-effort: silently skipped if the tool is
# missing (e.g. running outside the image without uv). Set false to disable.
STRUCTURAL_CONTEXT=true
# Launcher exposing `code-review-graph` on PATH (e.g. uvx, or an absolute path).
CODE_GRAPH_LAUNCHER=uvx
# The graph is built once per repo+base-branch and shared, read-only, across
# all concurrent reviews of that repo — so concurrent PRs never rebuild it or
# collide. Empty = ./data/graph-cache (same persistent volume as the DB), so
# graphs survive restarts and are reused across tasks. Back ./data with a volume.
# NOTE: assumes a per-host (not network-shared) cache dir; for a volume shared
# across replicas, switch the refresh lock to a DB advisory lock.
CODE_GRAPH_CACHE_DIR=
# Rebuild a repo's cached base graph once it is older than this (ms). Default 1h.
# (It also refreshes immediately when the base branch tip advances, for free.)
CODE_GRAPH_TTL_MS=3600000

# --- Worker / stateless recovery ---
# On startup, requeue jobs left "running" by a crashed/redeployed container.
# Assumes a single active worker; disable for multi-worker deployments.
RECOVER_INTERRUPTED_JOBS_ON_START=true

# --- Management API/UI auth ---
# --- Auth (multi-user) ---
# Signing secret for the app's OWN session tokens (minted after a successful
# OIDC login) and for deriving skill tokens. REQUIRED when OIDC is configured —
# the server refuses to start without it. Use a long random value, kept STABLE
# and SHARED across replicas (else sessions break on restart/rollout).
SESSION_SECRET=
# Session token lifetime in ms (default 7 days).
SESSION_TTL_MS=604800000
# Token-only break-glass admin (NOT stored in the DB). A request bearing this
# token authenticates as admin — used to bootstrap roles before any IdP user
# exists, and to drive the API/MCP. There is NO password login. Keep it secret.
ADMIN_EMAIL=admin@reviewpilot.local
ADMIN_TOKEN=
# Optional: override the directory of the built Web UI to serve.
WEB_DIST_DIR=

# --- Authentication: OpenID Connect (authentik) ---
# Authentication & registration are delegated to the IdP; this app keeps only
# authorization (role config). Set OIDC_ISSUER + OIDC_CLIENT_ID to enable login.
# Public base URL of THIS service (scheme://host, no trailing slash). Used to
# build the OIDC redirect URI and self links; prefer this over request headers.
PUBLIC_BASE_URL=
# Issuer = your authentik application's OIDC base (note the trailing slash);
# discovery is read from <issuer>/.well-known/openid-configuration.
#   e.g. https://auth.ihealthcn.com/application/o/review-platform/
OIDC_ISSUER=
OIDC_CLIENT_ID=
# Client secret for a confidential provider; leave empty for a public (PKCE-only)
# client. (This is the provider's Client Secret, NOT an authentik API token.)
OIDC_CLIENT_SECRET=
# Requested scopes; must include openid. Add the scope that carries groups if
# your provider exposes one.
OIDC_SCOPES=openid profile email
# ID-token claim holding the user's group names.
OIDC_GROUPS_CLAIM=groups
# Map authentik group names to local roles. Format: group:role,comma-separated.
#   e.g. reviewpilot-admins:admin,reviewpilot-members:member
OIDC_GROUP_ROLE_MAP=
# Delegate AUTHORIZATION to the IdP too. When true, each login (re)syncs the
# user's role from their groups — the IdP is authoritative, demotions apply, and
# the local role editor is disabled. When false (default), groups only seed the
# role at first login and admins manage it locally.
# WARNING before enabling: map an admin group above and make sure YOU are in it,
# or your next login demotes you to OIDC_DEFAULT_ROLE. Keep ADMIN_TOKEN as a
# break-glass to recover.
OIDC_SYNC_ROLES=false
# Role for a user whose groups match nothing in the map (viewer|member|admin).
OIDC_DEFAULT_ROLE=viewer
# Optional management REST API fallback (used only when the groups claim is
# absent): base URL + a service-account bearer token.
#   AUTHENTIK_API_URL=https://auth.ihealthcn.com/api/v3
AUTHENTIK_API_URL=
AUTHENTIK_API_TOKEN=

# --- GitHub provider ---
# Used by the service to read PRs and write back comments/checks.
GITHUB_API_BASE=https://api.github.com
# Static PAT (simple). Leave empty if using a GitHub App below.
GITHUB_TOKEN=
# GitHub App auth (preferred for production): short-lived, per-installation,
# higher rate limits. Set the App id and its PEM private key (escape newlines
# as \n on one line, or mount the file and pass its contents).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
# Optional: pin a single installation; otherwise resolved per repo.
GITHUB_APP_INSTALLATION_ID=

# --- GitLab provider ---
GITLAB_API_BASE=https://gitlab.com/api/v4
GITLAB_TOKEN=

# --- Scheduled daily scans ---
# Where scheduled-scan configs are stored when DB_DRIVER is not `mongo`
# (the `mongo` driver uses a `schedules` collection instead). Put this on a
# persistent volume for stateless deploys. The scheduler only runs when at
# least one enabled schedule exists.
SCHEDULE_STORE_FILE=./.reviewpilot/schedules.json
# Default Feishu (Lark) custom-bot webhook for scheduled-scan delivery. Used
# when a schedule doesn't set its own delivery.webhookUrl, so the push target
# can be configured once here at deploy time.
FEISHU_WEBHOOK_URL=

# --- Workspace for full-repo clones (ephemeral; safe to be tmpfs) ---
WORKSPACE_DIR=./.workspace
